DB_FILE_NAME="file:.data/app.db"
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# E2B Sandbox runtime
# Required for E2B-compatible providers that do not use api.e2b.app.
E2B_API_URL=
E2B_API_KEY=
# Optional; defaults to E2B's "base" template. Use a custom template with Node.js
# and the Claude Agent SDK pre-installed to reduce cold-start time.
E2B_TEMPLATE_ID=

# Claude Agent SDK — custom endpoint
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_MODEL=

TURSO_AUTH_TOKEN=
TURSO_DATABASE_URL=